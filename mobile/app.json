{
  "expo": {
    "name": "Spedex",
    "slug": "spedex",
    "owner": "udaypatnala",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#fbf8ff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.udayp.spedex",
      "adaptiveIcon": {
        "backgroundColor": "#24389c"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "a5c1db99-0908-4f51-b487-7939b2b8e20b"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ]
  }
}
